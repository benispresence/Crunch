# Copy to docker/.env and fill in real values before running
# `docker compose ... up`. Docker compose picks this up via `--env-file`.

# Host port that exposes the SPA + reverse-proxied API.
FRONTEND_PORT=8080

# Anthropic credentials — required for the AI chat. Leave blank to run
# without the assistant (the rest of the workspace still works).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Shared secret between backend and python-engine. Change in production.
PYTHON_ENGINE_TOKEN=dev-engine-token

# JWT signing secret for the backend's own auth. Change in production.
JWT_SECRET=change-me-in-production
