# Crunch — Docker deployment env vars.
#
# Copy this file to docker/.env and fill in real values. Docker compose
# picks it up via the `--env-file docker/.env` flag (see compose comment
# header). The backend runs in NODE_ENV=production and refuses to start
# if any of the three secrets below is missing or matches a known
# dev/example value.
#
# Quick start:
#   cp docker/.env.example docker/.env
#   # generate three independent random strings (re-run each):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   # paste them into JWT_SECRET, PYTHON_ENGINE_TOKEN, DATA_KEY below.
#   # set ANTHROPIC_API_KEY if you want the AI chat enabled.
#   docker compose -f docker/docker-compose.yml --env-file docker/.env up --build

# Host port that exposes the SPA + reverse-proxied API.
FRONTEND_PORT=8080

# Anthropic credentials — required for the AI chat. Leave blank to run
# without the assistant (the rest of the workspace still works).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# === REQUIRED — backend refuses to start without these in production ===

# Shared secret between backend and python-engine. Long random string,
# 32+ bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PYTHON_ENGINE_TOKEN=

# JWT signing secret. Long random string, 32+ bytes. Generate the same
# way as PYTHON_ENGINE_TOKEN above. Rotating this invalidates every
# existing session.
JWT_SECRET=

# Symmetric key used to encrypt connection passwords and the Anthropic
# API key at rest in the SQLite database. Generate with the same
# command. ⚠ If you lose this value, stored connection passwords become
# unrecoverable.
DATA_KEY=
